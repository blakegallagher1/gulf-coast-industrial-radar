# Gulf Coast Industrial Radar — environment template
# Copy to .env.local for `pnpm dev`. Never commit real values.

# ─── runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Gulf Coast Industrial Radar"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── database (Postgres + PostGIS) ──────────────────────────────────────────
# docker compose up -d  →  postgresql://postgres:postgres@localhost:5432/gcir
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gcir?schema=public
# Supabase production project:
#   ref: imgobphnhwkpilbmxdny
#   url: https://imgobphnhwkpilbmxdny.supabase.co
# Use the Supabase Dashboard database password for <DATABASE_PASSWORD>.
# DATABASE_URL=postgresql://postgres:<DATABASE_PASSWORD>@db.imgobphnhwkpilbmxdny.supabase.co:5432/postgres?schema=public&sslmode=require

# Optional Supabase browser/client values. This app currently uses Prisma
# direct database access; only set these if a Supabase client is added.
NEXT_PUBLIC_SUPABASE_URL=https://imgobphnhwkpilbmxdny.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_KhkUD_dCdgwwqMzTl_-mGw_v4utQc4w

# ─── auth (Clerk v7) ────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/radar
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/radar
# Allowlist (comma-separated) — first user; leave blank to allow all
GCIR_EMAIL_ALLOWLIST=blake@gallagherpropco.com
# Dev bypass — only honored when NODE_ENV !== production OR NEXT_PUBLIC_E2E === true
NEXT_PUBLIC_DISABLE_AUTH=false

# ─── openai (agent runtime) ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
AGENT_MODEL_ID=gpt-5.4
AGENT_MODEL_FALLBACK=gpt-5.4-mini
AGENT_TOOL_INTERNAL_TOKEN=

# ─── perplexity agent api (https://docs.perplexity.ai/docs/agent-api) ───────
# Used at dev-time for source schema research and at runtime for the
# AssemblyValidator (public-announcement check + entity research).
# Generate at https://www.perplexity.ai/settings/api — Bearer token.
# (Note: there is NO /me / user-info endpoint on Perplexity's public API.
# Composio's "current_user_info" 401 is a non-issue; only chat/completions
# and /v1/agent are exposed. The same key works for both.)
PERPLEXITY_API_KEY=pplx-...
# Default preset for runtime calls. Per-call override via modelKey.
# Options: fast-search · pro-search · deep-research · advanced-deep-research
PERPLEXITY_DEFAULT_PRESET=pro-search
# Daily org-wide budget cap (USD). Calls that would exceed throw.
# Bumped 25→50 in Phase 3.2 to absorb migration of 5 OpenAI agents to Perplexity.
PERPLEXITY_DAILY_BUDGET_USD=50
# Per-trigger validation cap (USD).
PERPLEXITY_PER_TRIGGER_BUDGET_USD=0.5
# Per-agent soft caps (USD/day, JSON). WARN-only — total daily spend is
# still gated by PERPLEXITY_DAILY_BUDGET_USD above. Useful for noisy agents.
# Example: '{"BriefWriter":5,"EntityResolution":3,"DocumentExtraction":12}'
PERPLEXITY_AGENT_BUDGETS=
# Retry tuning for transient 429/5xx (jittered exponential backoff).
PERPLEXITY_MAX_RETRIES=3

# ─── agent backend overrides ────────────────────────────────────────────────
# By default, all agents that route through callBackend() prefer Perplexity
# and fall back to OpenAI on PerplexityDisabledError or BudgetExceeded.
# Set AGENT_BACKEND_<NAME>=openai to force OpenAI for one agent without
# redeploying. Useful for instant rollback when a Perplexity preset misbehaves.
#   AGENT_BACKEND_DOCUMENTEXTRACTION=openai
#   AGENT_BACKEND_ENTITYRESOLUTION=openai
#   AGENT_BACKEND_INVESTORACTION=openai
#   AGENT_BACKEND_ANALYSTREVIEW=openai
#   AGENT_BACKEND_BRIEFWRITER=openai

# ─── budget alerting ────────────────────────────────────────────────────────
# When set, the budget-report cron (every 4h) sends a single email per UTC
# day if total Perplexity spend crosses BUDGET_ALERT_THRESHOLD (default 0.75
# = 75% of daily cap). Uses the same Resend account configured below for
# weekly briefs — leave RESEND_API_KEY blank to disable alerts entirely.
# /admin/runs surfaces the same status as a pull channel (red banner at top
# of the page when today's spend > 75%), so email is optional.
BUDGET_ALERT_TO_EMAIL=
BUDGET_ALERT_THRESHOLD=0.75

# ─── map (basemap tiles) ────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Optional self-hosted Martin tile server URL pattern
NEXT_PUBLIC_TILE_URL=

# ─── object storage (raw evidence) ──────────────────────────────────────────
EVIDENCE_BUCKET=
EVIDENCE_REGION=us-east-1
EVIDENCE_ACCESS_KEY=
EVIDENCE_SECRET_KEY=
EVIDENCE_LOCAL_DIR=.evidence-cache

# ─── source adapters (free public; tokens optional/none today) ──────────────
# URLs verified by Phase 3 dev-time research — see packages/adapters/src/research/<slug>.md
LED_FASTLANE_BASE=https://fastlaneng.louisianaeconomicdevelopment.com
LDEQ_EDMS_BASE=https://edms.deq.louisiana.gov
USACE_MVN_BASE=https://www.mvn.usace.army.mil
LPSC_BASE=https://lpscpubvalence.lpsc.louisiana.gov
LA_SOS_BASE=https://coraweb.sos.la.gov
SEC_EDGAR_USER_AGENT="Gulf Coast Industrial Radar contact@gallagherpropco.com"
SAM_GOV_API_KEY=
ASCENSION_ARCGIS_BASE=https://gis.ascensionparishla.gov/server/rest/services
# EBR — verified via Open Data hub probe on 2026-04-30. Layer 0 of
# Cadastral/Tax_Parcel exposes ASSESSMENT_NUM / OWNER / SALE_YEAR / FLOOD_ZONE.
EBR_ARCGIS_BASE=https://maps.brla.gov/gis/rest/services
# Calcasieu — original gis.calcasieuassessor.org is offline. Verified
# CPPJ public Parcels FeatureService at lak-dc-arcgis.cppj.net on 2026-04-30.
CALCASIEU_ARCGIS_BASE=https://lak-dc-arcgis.cppj.net/arcgis/rest/services

# ─── worker / scheduling ────────────────────────────────────────────────────
WORKER_CRON_ENABLED=false
WORKER_CRON_TICK_SECONDS=60

# ─── email / outreach (briefs) ─────────────────────────────────────────────
RESEND_API_KEY=
BRIEF_FROM_EMAIL="Gulf Coast Industrial Radar <radar@gallagherpropco.com>"

# ─── observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
HEALTHCHECK_TOKEN=

# ─── feature gates ──────────────────────────────────────────────────────────
FEATURE_AGENT_RUN=true
FEATURE_BRIEF_GENERATE=true
FEATURE_PROACTIVE_ALERTS=false
# Quiet Land Assembly Detector — Perplexity-backed validation pass.
# When true, every fired QLAD trigger gets a 2-step Perplexity pass before
# the alert is published.
FEATURE_PERPLEXITY_VALIDATION=false
# Live alerting (writes Alert rows on QLAD trigger). Independent of the
# Perplexity validation flag — you can run live alerting without validation.
FEATURE_QLAD_LIVE_ALERTING=false

# ── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Map tiles (share card thumbnails) ───────────────────
MAPTILER_KEY=

# ── Production launch checklist ─────────────────────────
# 1. Set FEATURE_QLAD_LIVE_ALERTING=true
# 2. Set FEATURE_PERPLEXITY_VALIDATION=true
# 3. Set WORKER_CRON_ENABLED=true
# 4. Set RESEND_API_KEY to a live Resend key
# 5. Set STRIPE_SECRET_KEY to live Stripe key
# 6. Set STRIPE_WEBHOOK_SECRET from Stripe dashboard
# 7. Set STRIPE_PRICE_ID to the $10/mo price ID
# 8. Configure Stripe webhook: https://yourdomain.com/api/webhooks/stripe
# 9. Enable Stripe Customer Portal in Stripe dashboard
