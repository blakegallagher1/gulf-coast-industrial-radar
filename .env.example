# ============================================================
# Gulf Coast Industrial Radar — environment variables
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/gcir_dev"

# ------------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------------
OPENAI_API_KEY="sk-..."
# Model used for OpenAI calls (default: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# ------------------------------------------------------------------
# Perplexity Agent API
# https://docs.perplexity.ai/
# ------------------------------------------------------------------
PERPLEXITY_API_KEY="pplx-..."

# Preset routing — controls which Perplexity Agent API preset is used
# for ALL calls that don't explicitly override it.
#
# Available presets (verified 2026-04-30):
#   fast-research    ~$0.002/call   3-step, no web tools
#   pro-search       ~$0.005/call   5-step, web_search enabled  ← recommended
#   deep-research    ~$0.015/call   10-step, web_search + fetch_url
#
# Leave blank to use the code default ("balanced" → pro-search).
PERPLEXITY_DEFAULT_PRESET=""

# Daily USD spend cap across ALL Perplexity calls in this process.
# Set to 0 or leave blank to disable the budget guard.
PERPLEXITY_DAILY_BUDGET_USD="5.00"

# ------------------------------------------------------------------
# Composio (tool execution platform)
# ------------------------------------------------------------------
COMPOSIO_API_KEY="..."

# ------------------------------------------------------------------
# QLAD pipeline
# ------------------------------------------------------------------
# Maximum number of sources to process in a single QLAD run.
QLAD_MAX_SOURCES="50"
# Minimum confidence score (0–1) to include a source in the output.
QLAD_MIN_CONFIDENCE="0.7"

# ------------------------------------------------------------------
# Next.js / API
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"

# ------------------------------------------------------------------
# Feature flags
# ------------------------------------------------------------------
# Enable the experimental deep-research pipeline (uses deep-research preset).
FEATURE_DEEP_RESEARCH="false"
# Enable the QLAD assembly validation step.
FEATURE_ASSEMBLY_VALIDATION="true"
