# Gulf Coast Industrial Radar — environment template
# Copy to .env.local for `pnpm dev`, or set in Vercel / Railway dashboard.
# Never commit real secrets.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Primary Postgres URL (used by Prisma at runtime and for migrations)
DATABASE_URL="postgresql://gcir:changeme@localhost:5432/gcir_dev"

# Direct (non-pooled) URL — required for prisma migrate in serverless envs
DIRECT_URL="postgresql://gcir:changeme@localhost:5432/gcir_dev"

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------

# Standard OpenAI API key — used by packages/agents/src/openai-client.ts
OPENAI_API_KEY="sk-proj-..."

# Model to use for structured extraction (default: gpt-4o-mini)
# Overriding here lets you switch to gpt-4o for higher accuracy.
OPENAI_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# Perplexity
# ---------------------------------------------------------------------------

# Perplexity API key — used by packages/agents/src/perplexity-client.ts
# Obtain from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY="pplx-..."

# Daily spend cap in USD. The agent checks this before every Perplexity call.
# Set to 0 or omit to disable the cap.
PERPLEXITY_DAILY_BUDGET_USD="5.00"

# Perplexity preset IDs — these must match the presets configured in the
# Perplexity dashboard (https://www.perplexity.ai/settings/api/presets).
# The defaults below match the preset names used in PPLX_PRESETS (perplexity-client.ts).
PPLX_PRESET_STRUCTURED="gcir-structured-extraction"
PPLX_PRESET_SEARCH="gcir-web-search"
PPLX_PRESET_DEEP_RESEARCH="gcir-deep-research"

# ---------------------------------------------------------------------------
# Composio
# ---------------------------------------------------------------------------

# Composio API key — used by the toolchain integrations layer
# Obtain from: https://app.composio.dev/settings
COMPOSIO_API_KEY="composio-..."

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Public base URL (used for link generation in emails, webhooks, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Feature flags
# Set to 'true' to enable the QLAD pipeline in staging/production
FEATURE_QLAD_PIPELINE="false"

# ---------------------------------------------------------------------------
# Optional: Sentry error tracking
# ---------------------------------------------------------------------------

# SENTRY_DSN="https://..."
# NEXT_PUBLIC_SENTRY_DSN="https://..."
