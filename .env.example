# Gulf Coast Industrial Radar вЂ” environment template
# Copy to .env.local for `pnpm dev`. Never commit real values.

# в”Ђв”Ђв”Ђ runtime в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Gulf Coast Industrial Radar"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# в”Ђв”Ђв”Ђ database (Postgres + PostGIS) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# docker compose up -d  в†’  postgresql://postgres:postgres@localhost:5432/gcir
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gcir?schema=public

# в”Ђв”Ђв”Ђ auth (Clerk v7) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/radar
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/radar
# Allowlist (comma-separated) вЂ” first user; leave blank to allow all
GCIR_EMAIL_ALLOWLIST=blake@gallagherpropco.com
# Dev bypass вЂ” gonly honored when NODE_ENV !== production OR NEXT_PUBLIC_E2E === true
NEXT_PUBLIC_DISABLE_AUTH=false

# в”Ђв”Ђв”Ђ openai (agent runtime) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
OPENAI_API_KEY=
AGENT_MODEL_ID=gpt-5.4
AGENT_MODEL_FALLBACK=gpt-5.2
AGENT_TOOL_INTERNAL_TOKEN=

# в”Ђв”Ђв”Ђ perplexity agent api (https://docs.perplexity.ai/docs/agent-api) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Used at dev-time for source schema research and at runtime for the
# AssemblyValidator (public-announcement check + entity research).
# Generate at https://www.perplexity.ai/settings/api вЂ” Bearer token.
# (Note: there is NO /me / user-info endpoint on Perplexity's public API.
# Composio's "current_user_info" 401 is a non-issue; only chat/completions
# and /v1/agent are exposed. The same key works for both.)
PERPLEXITY_API_KEY=
# Default preset for runtime calls. Per-call override via modelKey.
# Options: fast-search В· pro-search · deep-research В· advanced-deep-research
PERPLEXITY_DEFAULT_PRESET=pro-search
# Daily org-wide budget cap (USD). Calls that would exceed throw.
PERPLEXITY_DAILY_BUDGET_USD=25
# Per-trigger validation cap (USD).
PERPLEXITY_PER_TRIGGER_BUDGET_USD=0.5

# в”Ђв”Ђв”Ђ map (basemap tiles) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Optional self-hosted Martin tile server URL pattern
NEXT_PUBLIC_TILE_URL=

# в”Ђв”Ђв”Ђ object storage (raw evidence) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
EVIDENCE_BUCKET=
EVIDENCE_REGION=us-east-1
EVIDENCE_ACCESS_KEY=
EVIDENCE_SECRET_KEY=
EVIDENCE_LOCAL_DIR=.evidence-cache

# в”Ђв”Ђв”Ђ source adapters (free public; tokens optional/none today) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# URLs verified by Phase 3 dev-time research вЂ” see packages/adapters/src/research/<slug>.md
LED_FASTLANE_BASE=https://fastlaneng.louisianaeconomicdevelopment.com
LDEQ_EDMS_BASE=https://edms.deq.louisiana.gov
USACE_MVN_BASE=https://www.mvn.usace.army.mil
LPSC_BASE=https://lpscpubvalence.lpsc.louisiana.gov
LA_SOS_BASE=https://coraweb.sos.la.gov
SEC_EDGAR_USER_AGENT="Gulf Coast Industrial Radar contact@gallagherpropco.com"
SAM_GOV_API_KEY=
ASCENSION_ARCGIS_BASE=https://gis.ascensionparishla.gov/server/rest/services
EBR_ARCGIS_BASE=https://arcgis.brla.gov/server/rest/services
CALCASIEU_ARCGIS_BASE=https://gis.calcasieuassessor.org/arcgis/rest/services

# в”Ђв”Ђв”Ђ worker / scheduling в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
WORKER_CRON_ENABLED=false
WORKER_CRON_TICK_SECONDS=60

# в”Ђв”Ђв”Ђ email / outreach (briefs) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RESEND_API_KEY=
BRIEF_FROM_EMAIL="Gulf Coast Industrial Radar <radar@gallagherpropco.com>"

# в”Ђв”Ђв”Ђ observability в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
HEALTHCHECK_TOKEN=

# в”Ђв”Ђв”Ђ feature gates в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
FEATURE_AGENT_RUN=true
FEATURE_BRIEF_GENERATE=true
FEATURE_PROACTIVE_ALERTS=false
# Quiet Land Assembly Detector вЂ” Perplexity-backed validation pass.
# When true, every fired QLAD trigger gets a 2-step Perplexity pass before
# the alert is published.
FEATURE_PERPLEXITY_VALIDATION=false
# Live alerting (writes Alert rows on QLAD trigger). Independent of the
# Perplexity validation flag вЂ” you can run live alerting without validation.
FEATURE_QLAD_LIVE_ALERTING=false
