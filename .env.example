# Gulf Coast Industrial Radar — environment variables
# Copy to .env and fill in values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://gcir:password@localhost:5432/gcir_dev"

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── Perplexity Agent API (Phase 3) ────────────────────────────────────────────
# Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY="pplx-..."

# Enable/disable Perplexity validation (default: false — safe to deploy without key)
FEATURE_PERPLEXITY_VALIDATION="false"

# Daily USD budget cap for Perplexity calls (default: $25)
PERPLEXITY_DAILY_BUDGET_USD="25"

# ── SAM.gov ───────────────────────────────────────────────────────────────────
SAM_GOV_API_KEY=""

# ── Workers ───────────────────────────────────────────────────────────────────
# Cron schedule for qlad-evaluate worker (default: every 20 minutes)
QLAD_EVALUATE_SCHEDULE="*/20 * * * *"
