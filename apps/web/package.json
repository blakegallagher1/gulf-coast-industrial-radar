{
  "name": "@gcir/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -ac 'set -a; . ../../.env.local; set +a; exec next dev --turbopack'",
    "build": "next build",
    "vercel-build": "cd ../.. && pnpm db:generate && pnpm --filter @gcir/web build",
    "start": "sh -ac 'set -a; . ../../.env.local; set +a; exec next start'",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.16.0",
    "@gcir/adapters": "workspace:*",
    "@gcir/agents": "workspace:*",
    "@gcir/db": "workspace:*",
    "@gcir/scoring": "workspace:*",
    "@gcir/shared": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "maplibre-gl": "^4.7.1",
    "next": "16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.1.0",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
}
